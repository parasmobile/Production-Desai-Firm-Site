---
import Layout from '@/layouts/Layout.astro';
import CTASection from '@/components/CTASection.astro';

const familyLawPosts = [
  {
    slug: "50-50-custody-florida",
    title: "Can a Florida Parent Get 50/50 Custody? What the Equal Time-Sharing Presumption Really Means",
    description: "Florida law now presumes equal time-sharing is in a child's best interests — but 50/50 isn't automatic. Learn what the presumption means, how it can be rebutted, and what evidence courts look for.",
    category: "Child Custody",
    date: "2026-07-15",
    readTime: "9 min",
  },
  {
    slug: "divorce-florida-guide",
    title: "Divorce in Florida: A Complete Guide",
    description: "Everything you need to know about the Florida divorce process — timelines, property division, alimony, and how to protect your interests in St. Johns County.",
    category: "Divorce",
    date: "2026-06-16",
    readTime: "8 min",
  },
  {
    slug: "child-custody-timesharing-florida",
    title: "Child Custody & Timesharing in Florida: What Every Parent Needs to Know",
    description: "Florida uses 'timesharing' instead of custody. Learn how parenting plans work, how courts decide timesharing arrangements, and how to modify an existing order.",
    category: "Child Custody",
    date: "2026-06-16",
    readTime: "7 min",
  },
  {
    slug: "child-support-florida-guide",
    title: "Child Support in Florida: How It's Calculated and What to Expect",
    description: "Florida child support is set by statute using an income shares model. Learn how the calculation works, what can be modified, and what happens when support isn't paid.",
    category: "Child Support",
    date: "2026-06-16",
    readTime: "7 min",
  },
];

const businessLitigationPosts = [
  {
    slug: "florida-civil-litigation-deadlines-discovery",
    title: "Florida's New Civil Litigation Rules: What Plaintiffs and Defendants Need to Know About Case Deadlines and Discovery",
    description: "Florida's 2024–2025 amendments to the Rules of Civil Procedure bring active case management, initial disclosures, proportional discovery, and strict deadline enforcement. Here's what plaintiffs and defendants need to know.",
    category: "Business Litigation",
    date: "2026-07-15",
    readTime: "12 min",
  },
];

const personalInjuryPosts = [
  {
    slug: "florida-car-accident-value-tort-reform",
    title: "Florida Car Accident Value After Tort Reform",
    description: "Florida's 2023 tort reform changed the filing deadline, comparative-fault rule, and medical-bill evidence rules for car accident claims. Here's how those changes affect what a case is really worth.",
    category: "Car Accidents",
    date: "2026-07-15",
    readTime: "11 min",
  },
  {
    slug: "car-accident-florida",
    title: "Car Accidents in Florida: What to Do After a Crash",
    description: "Florida's no-fault insurance system, comparative fault rules, and strict deadlines make auto accident claims complex. Learn what steps to take — and what to avoid — after a crash in Northeast Florida.",
    category: "Car Accidents",
    date: "2026-06-16",
    readTime: "8 min",
  },
  {
    slug: "premises-liability-florida",
    title: "Premises Liability in Florida: Slip and Fall & Negligent Security",
    description: "When you're injured on someone else's property in Florida, premises liability law determines who is responsible. Learn about slip and fall claims, negligent security, and property owner duty of care.",
    category: "Premises Liability",
    date: "2026-06-16",
    readTime: "7 min",
  },
  {
    slug: "wrongful-death-florida",
    title: "Wrongful Death in Florida: Who Can Sue and What Damages Are Available",
    description: "When a loved one is killed due to another's negligence, Florida's Wrongful Death Act determines who can file a claim and what compensation is available.",
    category: "Wrongful Death",
    date: "2026-06-16",
    readTime: "6 min",
  },
];
---
<Layout
  title="Legal Blog & Resources | The Desai Firm, St. Augustine"
  description="Practical legal insights from Saint Augustine attorney Paras J. Desai on personal injury, car accidents, divorce, child custody, child support, business litigation, and Florida law."
  canonical="https://desaifirm.com/blog/"
>
  <section class="bg-primary py-16">
    <div class="container-legal px-4 sm:px-6 lg:px-8">
      <div class="gold-divider mb-6"></div>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-primary-foreground mb-4">Legal Insights & Resources</h1>
      <p class="text-primary-foreground/70 text-lg max-w-2xl">Practical guidance on Florida personal injury and family law from Saint Augustine attorney Paras J. Desai.</p>
    </div>
  </section>

  <section class="section-padding bg-background">
    <div class="container-legal px-4 sm:px-6 lg:px-8">

      <!-- Personal Injury -->
      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="gold-divider w-8 shrink-0"></div>
          <h2 class="font-heading text-2xl font-bold text-foreground">Personal Injury</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {personalInjuryPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block bg-card border border-border rounded-lg overflow-hidden hover:border-accent hover:shadow-lg transition-all duration-300">
              <div class="bg-primary/5 border-b border-border px-6 py-4">
                <span class="text-xs font-semibold tracking-widest uppercase text-accent">{post.category}</span>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg font-bold text-card-foreground mb-3 leading-snug group-hover:text-accent transition-colors">{post.title}</h3>
                <p class="text-muted-foreground text-sm leading-relaxed mb-4">{post.description}</p>
                <div class="flex items-center justify-between text-xs text-muted-foreground">
                  <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  <span>{post.readTime} read</span>
                </div>
              </div>
              <div class="px-6 pb-5">
                <span class="inline-flex items-center text-accent text-sm font-medium">
                  Read Article
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Family Law -->
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="gold-divider w-8 shrink-0"></div>
          <h2 class="font-heading text-2xl font-bold text-foreground">Family Law</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {familyLawPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block bg-card border border-border rounded-lg overflow-hidden hover:border-accent hover:shadow-lg transition-all duration-300">
              <div class="bg-primary/5 border-b border-border px-6 py-4">
                <span class="text-xs font-semibold tracking-widest uppercase text-accent">{post.category}</span>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg font-bold text-card-foreground mb-3 leading-snug group-hover:text-accent transition-colors">{post.title}</h3>
                <p class="text-muted-foreground text-sm leading-relaxed mb-4">{post.description}</p>
                <div class="flex items-center justify-between text-xs text-muted-foreground">
                  <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  <span>{post.readTime} read</span>
                </div>
              </div>
              <div class="px-6 pb-5">
                <span class="inline-flex items-center text-accent text-sm font-medium">
                  Read Article
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Business Litigation -->
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="gold-divider w-8 shrink-0"></div>
          <h2 class="font-heading text-2xl font-bold text-foreground">Business Litigation</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {businessLitigationPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block bg-card border border-border rounded-lg overflow-hidden hover:border-accent hover:shadow-lg transition-all duration-300">
              <div class="bg-primary/5 border-b border-border px-6 py-4">
                <span class="text-xs font-semibold tracking-widest uppercase text-accent">{post.category}</span>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg font-bold text-card-foreground mb-3 leading-snug group-hover:text-accent transition-colors">{post.title}</h3>
                <p class="text-muted-foreground text-sm leading-relaxed mb-4">{post.description}</p>
                <div class="flex items-center justify-between text-xs text-muted-foreground">
                  <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  <span>{post.readTime} read</span>
                </div>
              </div>
              <div class="px-6 pb-5">
                <span class="inline-flex items-center text-accent text-sm font-medium">
                  Read Article
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <CTASection />
</Layout>
