---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Page Not Found | The Desai Firm"
  description="The page you're looking for doesn't exist."
>
  <div class="flex min-h-screen items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Page not found</p>
      <a href="/" class="text-accent underline hover:text-accent/80">Return to Home</a>
    </div>
  </div>
</Layout>
