---
interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = "Ready to Discuss Your Case?",
  subtitle = "Contact The Desai Firm today for a practical assessment of your legal matter.",
} = Astro.props;
---
<section class="bg-primary section-padding">
  <div class="container-legal text-center">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-primary-foreground mb-4">{title}</h2>
    <p class="text-primary-foreground/70 text-lg mb-8 max-w-2xl mx-auto">{subtitle}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/contact">
        <button class="inline-flex items-center justify-center rounded-md bg-accent text-accent-foreground hover:bg-gold-light font-semibold px-8 py-3 text-base transition-colors">
          Request a Free Consultation
        </button>
      </a>
      <a href="tel:9045636952">
        <button class="inline-flex items-center justify-center rounded-md border border-white/80 bg-white/15 text-white hover:bg-white/25 font-semibold px-8 py-3 text-base transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (904) 563-6952
        </button>
      </a>
    </div>
  </div>
</section>
