---
import PageHero from '@/components/PageHero.astro';
import CTASection from '@/components/CTASection.astro';

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  title: string;
  breadcrumb: string;
  heroSubtitle: string;
  commonIssues: string[];
  whatWeDo: string[];
  whatToExpect: string[];
  faqs: FAQ[];
}

const { title, breadcrumb, heroSubtitle, commonIssues, whatWeDo, whatToExpect, faqs } = Astro.props;

// BreadcrumbList JSON-LD from the breadcrumb prop (e.g. "Practice Areas / Family Law")
const breadcrumbParts = ["Home", ...breadcrumb.split(" / ")];
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbParts.map((name, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": name,
  })),
};

// FAQPage JSON-LD from the faqs prop
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
<PageHero title={title} subtitle={heroSubtitle} breadcrumb={breadcrumb} />

<section class="section-padding bg-background">
  <div class="container-legal max-w-4xl">
    <div class="prose text-foreground/80 space-y-4 text-lg leading-relaxed">
      <slot name="overview" />
    </div>
  </div>
</section>

<section class="section-padding bg-cream">
  <div class="container-legal max-w-4xl">
    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">Common Issues We Handle</h2>
    <div class="gold-divider mb-8"></div>
    <ul class="grid md:grid-cols-2 gap-3">
      {commonIssues.map((item) => (
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-foreground">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="section-padding bg-background">
  <div class="container-legal max-w-4xl">
    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">What We Do</h2>
    <div class="gold-divider mb-8"></div>
    <ul class="space-y-3">
      {whatWeDo.map((item) => (
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-foreground/80 leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="section-padding bg-cream">
  <div class="container-legal max-w-4xl">
    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">What to Expect</h2>
    <div class="gold-divider mb-8"></div>
    <ul class="space-y-3">
      {whatToExpect.map((item) => (
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-foreground/80 leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="section-padding bg-background">
  <div class="container-legal max-w-4xl">
    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">Frequently Asked Questions</h2>
    <div class="gold-divider mb-8"></div>
    <div class="space-y-6">
      {faqs.map((faq) => (
        <div class="border-b border-border pb-6">
          <h3 class="font-heading text-lg font-semibold text-foreground mb-3">{faq.q}</h3>
          <p class="text-muted-foreground leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
    <p class="text-xs text-muted-foreground mt-8 italic">
      This information is for general educational purposes only and does not constitute legal advice. Consult with an attorney for advice specific to your situation.
    </p>
  </div>
</section>

<CTASection />
