---
import Layout from '@/layouts/Layout.astro';
import CTASection from '@/components/CTASection.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  publishDate: string;
  category: string;
  readTime: string;
  relatedLinks?: { label: string; href: string }[];
}

const { title, description, canonical, publishDate, category, readTime, relatedLinks } = Astro.props;

const defaultRelatedLinks = [
  { label: "Family Law Overview", href: "/practice-areas/family-law" },
  { label: "Divorce", href: "/practice-areas/family-law/divorce" },
  { label: "Child Custody & Timesharing", href: "/practice-areas/family-law/child-custody" },
  { label: "Civil Litigation", href: "/practice-areas/civil-litigation" },
];

const sidebarLinks = relatedLinks ?? defaultRelatedLinks;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonical,
  "datePublished": publishDate,
  "dateModified": publishDate,
  "author": {
    "@type": "Person",
    "name": "Paras J. Desai",
    "url": "https://desaifirm.com/about",
    "jobTitle": "Attorney",
    "worksFor": { "@type": "LegalService", "name": "The Desai Firm" }
  },
  "publisher": {
    "@type": "LegalService",
    "name": "The Desai Firm",
    "url": "https://desaifirm.com"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://desaifirm.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://desaifirm.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonical },
  ]
};
---
<Layout {title} {description} {canonical} jsonLd={[articleJsonLd, breadcrumbJsonLd]}>
  <!-- Hero -->
  <section class="bg-primary py-16">
    <div class="container-legal px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-semibold tracking-widest uppercase text-accent">{category}</span>
          <span class="text-primary-foreground/40">·</span>
          <span class="text-xs text-primary-foreground/50">{readTime} read</span>
          <span class="text-primary-foreground/40">·</span>
          <span class="text-xs text-primary-foreground/50">{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        <div class="gold-divider mb-6"></div>
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary-foreground leading-tight mb-6">{title}</h1>
        <p class="text-primary-foreground/70 text-lg leading-relaxed">{description}</p>
        <div class="mt-6 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-sm">PD</div>
          <div>
            <p class="text-primary-foreground text-sm font-semibold">Paras J. Desai, Esq.</p>
            <p class="text-primary-foreground/50 text-xs">Florida Bar No. 030827 · The Desai Firm</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-background">
    <div class="container-legal px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12 max-w-5xl">
        <!-- Article body -->
        <article class="prose prose-lg max-w-none text-foreground/80 leading-relaxed
          [&_h2]:font-heading [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-foreground [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:font-heading [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-foreground [&_h3]:mt-6 [&_h3]:mb-3
          [&_p]:mb-5 [&_ul]:mb-5 [&_ol]:mb-5 [&_li]:mb-2
          [&_a]:text-accent [&_a]:font-medium [&_a:hover]:underline
          [&_strong]:text-foreground [&_strong]:font-semibold">
          <slot />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-primary rounded-lg p-6 text-center sticky top-8">
            <p class="text-accent text-xs font-semibold tracking-widest uppercase mb-3">Free Consultation</p>
            <h2 class="font-heading text-xl font-bold text-primary-foreground mb-3">Have Questions About Your Case?</h2>
            <p class="text-primary-foreground/70 text-sm mb-5 leading-relaxed">Every family situation is different. Speak with Paras J. Desai directly to understand your options.</p>
            <a href="/contact">
              <button class="w-full inline-flex items-center justify-center rounded-md bg-accent text-accent-foreground hover:bg-gold-light font-semibold px-6 py-3 text-sm transition-colors mb-3">
                Request a Consultation
              </button>
            </a>
            <a href="tel:9045636952">
              <button class="w-full inline-flex items-center justify-center rounded-md border border-white/40 bg-white/10 text-white hover:bg-white/20 font-semibold px-6 py-3 text-sm transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                (904) 563-6952
              </button>
            </a>
            <p class="text-primary-foreground/40 text-xs mt-4">Florida Bar Licensed · Northeast Florida</p>
          </div>

          <div class="bg-muted rounded-lg p-5">
            <p class="font-heading font-semibold text-foreground mb-3 text-sm">Related Practice Areas</p>
            <ul class="space-y-2">
              {sidebarLinks.map((link) => (
                <li><a href={link.href} class="text-accent text-sm hover:underline flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>{link.label}</a></li>
              ))}
            </ul>
          </div>

          <div class="border border-border rounded-lg p-5">
            <p class="text-xs text-muted-foreground leading-relaxed italic">
              <strong class="text-foreground not-italic">Disclaimer:</strong> This article is for general informational purposes only and does not constitute legal advice. Every case is different. Consult with a licensed Florida attorney for advice specific to your situation.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
